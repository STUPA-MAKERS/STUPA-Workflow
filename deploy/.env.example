# Antragsplattform — Secrets/Config-Layout (sds/deployment.md §3).
# Kopiere nach `deploy/.env` und fülle Werte. `.env` NIE committen.
# Alle Secrets nur hier; rotierbar.

# DB
POSTGRES_DB=antrag
POSTGRES_USER=app
POSTGRES_PASSWORD=
DATABASE_URL=postgresql+asyncpg://app:@postgres/antrag
DB_MIGRATION_URL=postgresql+psycopg://migrator:@postgres/antrag   # eigener User
AUDIT_DB_ROLE=audit_writer                                         # nur INSERT/SELECT

# Redis / MinIO
REDIS_URL=redis://redis:6379/0
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=attachments

# Auth
OIDC_ISSUER=https://keycloak.example/realms/<realm>
OIDC_CLIENT_ID=antrag
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=https://antrag.example/api/auth/callback
SESSION_SECRET=           # Server-Session-Signing
MAGIC_LINK_SECRET=        # zusätzlicher HMAC-Pepper für Token-Hash

# Proxy
FORWARDED_ALLOW_IPS=      # NPM-IP/Netz
PUBLIC_BASE_URL=https://antrag.example

# Mail
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=starttls

# Nextcloud (WebDAV)
NEXTCLOUD_WEBDAV_URL=https://cloud.example/remote.php/dav/files/<user>/
NEXTCLOUD_USER=
NEXTCLOUD_APP_PASSWORD=
NEXTCLOUD_BASE_PATH=Antraege/

# Webhooks / Captcha / pytex
WEBHOOK_HMAC_KEY=
WEBHOOK_ALLOWLIST=host1,host2     # optional zusätzlich zu IP-Block
# ALTCHA Sentinel (Captcha). Erst-Login: root / <ALTCHA_ROOT_PASSWORD> (Default
# root/root — vor Prod ändern). ALTCHA_HMAC_SECRET signiert Challenges und muss
# später mit der Backend-Captcha-Verifikation geteilt werden. Leer ⇒ Sentinel
# generiert es selbst nach /data/.env (dann aus Container auslesen).
ALTCHA_ROOT_PASSWORD=root
ALTCHA_HMAC_SECRET=
PYTEX_URL=http://pytex:8099
PYTEX_TRUST=trusted
# pytex-Service-Defaults (greifen, wenn der Query-Param fehlt); optional:
# PYTEX_DEFAULT_OUTPUT=pdf
# PYTEX_DEFAULT_TRUST=trusted
# PYTEX_MAX_BODY_BYTES=4194304
