{
  "name": "antragsplattform-frontend",
  "version": "0.0.0",
  "description": "Antragsplattform SPA — Skelett + Design-System (T-03)",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "e2e": "playwright test",
    "e2e:tsc": "tsc -p e2e/tsconfig.json --noEmit"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.0",
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@angular/service-worker": "^20.3.0",
    "@fontsource/archivo": "^5.2.0",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@ngx-formly/core": "^7.0.0",
    "@tiptap/core": "^3.26.0",
    "@tiptap/pm": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "rxjs": "~7.8.0",
    "tiptap-markdown": "^0.9.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^20.0.0",
    "@angular-eslint/eslint-plugin": "^20.0.0",
    "@angular-eslint/eslint-plugin-template": "^20.0.0",
    "@angular-eslint/schematics": "^20.0.0",
    "@angular-eslint/template-parser": "^20.0.0",
    "@angular/build": "^20.3.27",
    "@angular/cli": "^20.3.27",
    "@angular/compiler-cli": "^20.3.0",
    "@eslint/js": "^9.16.0",
    "@playwright/test": "^1.49.1",
    "@testing-library/angular": "^17.3.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^22.10.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.16.0",
    "jest": "^29.7.0",
    "jest-axe": "^9.0.0",
    "jest-preset-angular": "^14.4.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.18.0"
  }
}